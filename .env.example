# ─── Supabase (hosted / Vercel version) ───────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
# Set in Vercel dashboard: Project Settings → Environment Variables

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Local server Supabase sync (optional, for two-way sync) ──────────────────
# If set, Open CRM.command will sync local writes to Supabase automatically.
# Use the SERVICE ROLE key here (not the anon key) — keep this private.
# Get from: supabase.com → your project → Settings → API → service_role

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── I&E gap-check endpoint (REX-TODO-001) ────────────────────────────────────
# api/ie-crm-gap-check.js reads the private I&E Google Sheet via a Google Cloud
# service account. Paste the full stringified JSON of the downloaded service
# account key here. Keep it on a single line — the endpoint converts the
# two-character "\n" sequences inside private_key back to real newlines.
# The service account's client_email must be granted Viewer on the I&E sheet.
# Scope used: https://www.googleapis.com/auth/spreadsheets.readonly

GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"dt-ie-reader@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Shared secret required on the Authorization: Bearer <token> header for cron
# endpoints (ie-crm-gap-check, proposal-followup-cron).
CRON_SECRET=replace-with-a-long-random-string

# ─── Notes ────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real credentials.
# Without these vars, the app runs in local-only mode (reads/writes local JSON).
